# CricketData.org API key — sign up at https://cricketdata.org
# S plan ($5.99/mo, 2000 hits/day) is enough for dev + early production
# Upgrade to M ($12.99/mo, 10k hits/day) before launch
CRICAPI_KEY=your_cricketdata_key_here

# Anthropic API key for AI analysis
ANTHROPIC_API_KEY=your_anthropic_key_here

# App settings
ENVIRONMENT=development
SECRET_KEY=change_me_in_production

# Adjust to match your CricAPI plan limit
CRICAPI_DAILY_LIMIT=10000
